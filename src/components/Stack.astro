---
import { stacks } from '../data/profile';
---

<section id="stack" class="stack container">
  <div class="section-grid">
    <div>
      <span class="ghost-numeral" aria-hidden="true">03</span>
      <p class="micro-label">Stack</p>
    </div>
    <div class="stack__table">
      {stacks.map((g) => (
        <div class="stack__row">
          <h2 class="stack__name">{g.group}</h2>
          <p class="stack__items">{g.items.join(' · ')}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack { padding-bottom: 96px; }
  .stack__table { display: flex; flex-direction: column; }
  .stack__row {
    display: grid; grid-template-columns: 1fr 2fr; gap: 16px;
    border-bottom: 1px solid var(--hairline); padding: 18px 0;
    align-items: baseline;
  }
  .stack__row:first-child { padding-top: 0; }
  .stack__name { font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); font-weight: 500; font-family: var(--font-body); }
  .stack__items { font-size: 0.95rem; color: var(--ink); }
  @media (max-width: 760px) {
    .stack__row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
