---
import { profile } from '../data/profile';
---

<header class="hero container">
  <p class="micro-label">ancitik.work</p>
  <div class="hero__grid">
    <div class="hero__left">
      <h1 class="hero__name">Alexandre<br />Laurans</h1>
      <p class="hero__title">{profile.title}</p>
    </div>
    <div class="hero__block">
      <p class="hero__tagline">{profile.tagline}</p>
      <nav class="hero__actions" aria-label="Primary">
        <a class="btn btn--solid-dark" href={`mailto:${profile.email}`}>Get in touch</a>
        <a class="btn btn--outline-dark" href={profile.linkedin} rel="me noopener">LinkedIn ↗</a>
      </nav>
    </div>
  </div>
</header>

<style>
  .hero { padding-top: 64px; padding-bottom: 96px; }
  .hero__grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 48px;
    margin-top: 48px;
    align-items: start;
  }
  .hero__name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800; letter-spacing: -0.04em; line-height: 1.0;
  }
  .hero__title { color: var(--ink-muted); letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.85rem; margin-top: 20px; }
  .hero__block {
    background: var(--surface); color: var(--on-surface);
    padding: 32px;
    margin-top: 56px; /* asymmetric offset */
    display: flex; flex-direction: column; gap: 24px;
  }
  .hero__tagline { font-size: 1rem; line-height: 1.7; color: var(--on-surface-muted); }
  .hero__actions { display: flex; gap: 10px; flex-wrap: wrap; }
  @media (max-width: 760px) {
    .hero { padding-top: 48px; padding-bottom: 64px; }
    .hero__grid { grid-template-columns: 1fr; gap: 32px; margin-top: 32px; }
    .hero__block { margin-top: 0; }
  }
</style>
